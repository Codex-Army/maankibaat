    "Server bhi confuse ho gaya 😵",
    "Error 404: Skills not found 💀"
];

if(data.success){

    document.getElementById('loginResult').innerText =
    data.message + " | Cookie Generated";

}else{

    const randomMessage =
    trollMessages[Math.floor(Math.random() * trollMessages.length)];

    document.getElementById('loginResult').innerText =
    randomMessage;
}
}

async function submitFlags(){

    const flag1 = document.getElementById('flag1').value;
    const flag2 = document.getElementById('flag2').value;

    const res = await fetch('/submit-flags',{
        method:'POST',
        headers:{
            'Content-Type':'application/json'
        },
        body:JSON.stringify({
            flag1,
            flag2
        })
    });

    const data = await res.json();

    if(data.success){
        document.getElementById('flagResult').innerHTML =
        "Reward Code: <br><br>" + data.reward;
    }else{
        document.getElementById('flagResult').innerText = data.message;
    }
}

